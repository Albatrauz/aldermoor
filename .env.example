# ---- Convex configuration ----
# Copy to .env.local for development. `npx convex dev` writes CONVEX_DEPLOYMENT
# and prints the deployment URL to use below.

# Browser read client (ConvexClient). Public — Vite inlines it into the build.
# In production this MUST be present at BUILD time (Coolify build arg/env).
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# server.js HTTP client (ConvexHttpClient). Same deployment URL, no VITE_ prefix.
CONVEX_URL=https://your-deployment.convex.cloud

# Shared secret guarding the stat-write mutations. Generate a long random value
# and set the SAME value in the Convex deployment env:  npx convex env set SERVER_SHARED_SECRET <value>
SERVER_SHARED_SECRET=change-me-to-a-long-random-string

# Optional: reject unauthenticated players entirely (default: guests allowed, no stats).
# ALLOW_GUESTS=false
